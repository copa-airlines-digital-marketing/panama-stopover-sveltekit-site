{
  "name": "panama-stopover-sveltekit-site",
  "version": "2.10.1",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "doppler run -- vite dev --host --port 1614",
    "dev:local": "vite dev --host --port 1614",
    "build": "vite build",
    "build:local": "doppler run -- vite build",
    "preview": "vite preview",
    "preview:local": "doppler run -- vite preview",
    "test": "pnpm run test:integration && npm run test:unit",
    "test:local": "doppler run -- pnpm run test:integration && doppler run -- npm run test:unit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:local": "doppler run -- svelte-kit sync && doppler run -- svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "lint:local": "doppler run -- prettier --check . && doppler run -- eslint .",
    "format": "prettier --write .",
    "format:local": "doppler run -- prettier --write .",
    "test:integration": "playwright test",
    "test:integration:local": "doppler run -- playwright test",
    "test:unit": "vitest",
    "test:unit:local": "doppler run -- vitest",
    "start": "node build/index.js",
    "start:local": "doppler run -- node build/index.js",
    "doppler:login": "doppler login",
    "doppler:secrets": "doppler secrets get",
    "doppler:download": "doppler secrets download --format env > .env.doppler.local",
    "doppler:status": "doppler status"
  },
  "devDependencies": {
    "@directus/sdk": "^18.0.3",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/ramda": "^0.30.2",
    "@upstash/redis": "^1.38.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.19.3",
    "ramda": "^0.30.1",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.8",
    "zod": "^3.24.1"
  },
  "type": "module",
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@prisma/client": "^6.19.3",
    "@types/google.maps": "^3.58.1",
    "@upstash/ratelimit": "^2.0.8",
    "dotenv": "^16.4.7",
    "embla-carousel": "^8.5.1",
    "embla-carousel-fade": "^8.5.1",
    "embla-carousel-svelte": "^8.5.1",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "svelte-sonner": "^0.3.28",
    "vaul-svelte": "^0.3.2"
  },
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2",
      "yaml": "1.10.3"
    }
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
